# Скопируй этот файл в `.env` или задай переменные в shell перед запуском.
# Приложение автоматически читает `.env` из корня репозитория.

NODE_ENV=development
LOG_LEVEL=info

PORT=3000
HTTP_BIND_HOST=127.0.0.1
APP_BASE_URL=http://localhost:3000
MCP_HTTP_PATH=/mcp

DEFAULT_TENANT_ID=local-default
DEFAULT_TENANT_NAME=Local Default Tenant

LOCAL_ADMIN_ACCOUNT_ID=local-admin
LOCAL_ADMIN_EMAIL=local-admin@example.com
LOCAL_ADMIN_NAME=Local Admin

LOCAL_DEV_CLIENT_ID=local-dev-client
LOCAL_DEV_CLIENT_SECRET=local-dev-secret
LOCAL_DEV_REDIRECT_URI=http://127.0.0.1:8787/callback

OIDC_DEV_INTERACTIONS=true
ENABLE_ADMIN_WRITE_TOOLS=true
ENABLE_DELETE_TOOLS=false
ENABLE_WEBHOOK_MUTATIONS=true

AMO_INTEGRATION_ID=replace-me
AMO_CLIENT_SECRET=replace-me
AMO_BASE_DOMAIN=example.amocrm.ru
AMO_ACCOUNT_ID=
AMO_REDIRECT_URI=http://localhost:3000/oauth/amocrm/callback
WEBHOOK_SHARED_SECRET=local-webhook-secret

# Optional server-side infrastructure
# POSTGRES_URL=postgres://postgres:postgres@localhost:5432/amocrm_mcp
# REDIS_URL=redis://localhost:6379
